PORT=3001
MONGODB_URI=mongodb://localhost:27017/sadad
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRATION=7d

# Web app URL used to build reset-password links
APP_BASE_URL=http://localhost:3000

# Comma-separated CORS origins; empty means allow all (development only)
CORS_ORIGIN=http://localhost:3000

# Auth cookie settings
# Local development:
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_SECURE=false
# Cross-site production frontend/backend:
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false

# Password reset behavior:
# false in production (recommended), true for local testing.
AUTH_RETURN_RESET_TOKEN=true

# Optional Resend email provider
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
